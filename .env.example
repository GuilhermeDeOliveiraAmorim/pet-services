# Exemplo de variáveis de ambiente para o projeto pet-services

# Banco de Dados
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pet_services
DATABASE_URL=postgres://postgres:postgres@postgres:5432/pet_services?sslmode=disable

# Minio
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123

# API
PORT=8080
JWT_ACCESS_SECRET=your-secret-key-here-min-32-chars-dev
JWT_REFRESH_SECRET=your-refresh-secret-here-min-32-chars-dev
JWT_ACCESS_DURATION=15m
JWT_REFRESH_DURATION=168h
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=test@example.com
SMTP_PASS=test
SMTP_FROM=noreply@petservices.com
PASSWORD_RESET_BASE_URL=http://localhost:3000/reset-password
EMAIL_VERIFY_BASE_URL=http://localhost:3000/verify-email
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
LOG_LEVEL=info