# Database
DATABASE_URL=postgres://user:password@localhost:5432/pet_services
# OR use individual components:
# DB_USER=postgres
# DB_PASS=password
# DB_NAME=pet_services
# DB_HOST=localhost
# DB_PORT=5432
# DB_SSLMODE=disable

# Server
PORT=8080

# Auth (JWT secrets - generate with: openssl rand -hex 32)
# For development, you can use any string. For production, use strong secrets.
JWT_ACCESS_SECRET=your-secret-key-here-min-32-chars-dev
JWT_REFRESH_SECRET=your-refresh-secret-here-min-32-chars-dev
JWT_ACCESS_DURATION=15m
JWT_REFRESH_DURATION=168h

# Email Service (Brevo SMTP)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-smtp-user
SMTP_PASS=your-brevo-smtp-key
SMTP_FROM=noreply@petservices.com

# URLs for email links
PASSWORD_RESET_BASE_URL=https://app.petservices.com/reset-password
EMAIL_VERIFY_BASE_URL=https://app.petservices.com/verify-email

# CORS
CORS_ORIGINS=*

# Logging
LOG_LEVEL=info

# Storage Provider: minio or gcs
# For development, use MinIO. For production, use Google Cloud Storage.
STORAGE_PROVIDER=minio

# MinIO (Object Storage) - for development
MINIO_ROOT_USER=petimages
MINIO_ROOT_PASSWORD=petimages123
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9002
MINIO_BUCKET=pet-services
MINIO_USE_SSL=false
MINIO_DATA_PATH=/media/guilherme/HD 1TB/minio
MINIO_ACCESS_KEY=petimages
MINIO_SECRET_KEY=petimages123

# Google Cloud Storage - for production
# To generate credentials:
# 1. Go to Google Cloud Console (console.cloud.google.com)
# 2. Create a service account with Storage Admin role
# 3. Download the JSON key file
# 4. Set GCS_CREDENTIALS_PATH to the path of that file
# GCS_PROJECT_ID=your-gcp-project-id
# GCS_BUCKET_NAME=your-bucket-name
# GCS_CREDENTIALS_PATH=/path/to/service-account-key.json
